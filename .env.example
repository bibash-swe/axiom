# CRITICAL INVARIANTS: STATE MACHINE TIMEOUTS
# DO NOT TUNE INDEPENDENTLY. Breaking this hierarchy guarantees split-brain
# execution and silent data corruption.
# INVARIANT: LEASE < XAUTOCLAIM < JANITOR

# DB Fencing Lease: Max execution time before Postgres rejects worker writes.
AXIOM_WORKER_LEASE_SECONDS=30

# Redis PEL Recovery: Idle time before XAUTOCLAIM reassigns the message.
# MUST BE > LEASE to ensure the original worker is mathematically locked out.
AXIOM_WORKER_XAUTOCLAIM_MIN_IDLE_SECONDS=35

# GC Sweep: Background reconciliation for DB-terminal/Redis-zombie states.
# MUST BE > XAUTOCLAIM to allow the active recovery loop to self-heal first.
# (Note: The margin only needs to definitively clear the recovery window;
# excessive padding is an operational anti-pattern, not a safety mechanism).
AXIOM_JANITOR_IDLE_THRESHOLD_SECONDS=90

# DOCKER INFRASTRUCTURE
# Consumed strictly by docker-compose to spin up the pg 18 container
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=your_db_name

# DATABASE CONFIGURATION
# Unified connection string (DSN) for asyncpg
AXIOM_DATABASE_URL=postgresql://your_db_user:your_db_password@localhost:5432/your_db_name

# Connection pool tuning (Concurrency bounds)
AXIOM_DB_POOL_MIN_SIZE=2
AXIOM_DB_POOL_MAX_SIZE=10

# APPLICATION SETTINGS
AXIOM_LOG_LEVEL=INFO
AXIOM_ENV=development

#REDIS
AXIOM_REDIS_URL=redis://localhost:6379/0

# RELAY CONFIGURATION
# Batch size for sweeping the outbox table
AXIOM_RELAY_BATCH_SIZE=100
# How long the relay holds a claim before a parallel process can steal it
AXIOM_RELAY_CLAIM_LEASE_SECONDS=30
# Aggressive timeout: we never want the relay hanging on network I/O
AXIOM_RELAY_REDIS_SOCKET_TIMEOUT_SECONDS=1
# Poison pill threshold: how many times a message can fail to publish before dead-lettering
AXIOM_RELAY_MAX_RETRIES=5