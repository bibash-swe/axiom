# CRITICAL INVARIANTS: STATE MACHINE TIMEOUTS
# DO NOT TUNE INDEPENDENTLY. Breaking this hierarchy guarantees split-brain
# execution and silent data corruption.
# INVARIANT: LEASE < XAUTOCLAIM < JANITOR

# DB Fencing Lease: Max execution time before Postgres rejects worker writes.
AXIOM_WORKER_LEASE_SECONDS=30

# Redis PEL Recovery: Idle time before XAUTOCLAIM reassigns the message.
# MUST BE > LEASE to ensure the original worker is mathematically locked out.
AXIOM_WORKER_XAUTOCLAIM_MIN_IDLE_SECONDS=35

# GC Sweep: Background reconciliation for DB-terminal/Redis-zombie states.
# MUST BE > XAUTOCLAIM to allow the active recovery loop to self-heal first.
# (Note: The margin only needs to definitively clear the recovery window;
# excessive padding is an operational anti-pattern, not a safety mechanism).
AXIOM_JANITOR_IDLE_THRESHOLD_SECONDS=90

# DATABASE CREDENTIALS
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=your_db_name